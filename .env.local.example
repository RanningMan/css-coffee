# Copy this file to `.env.local` and fill in values as needed.
# `.env.local` is gitignored — never commit secrets.

# The "Generate Your Own Playground" route proxies to the ai-blogger-agent
# generation API. Point this at:
#   - Local dev:  http://localhost:4000  (run `npm run serve` in ai-blogger-agent)
#   - Production: your deployed Vercel URL, e.g. https://ai-blogger-agent.vercel.app
# The OpenAI key lives in the agent, not here.
AGENT_API_URL=http://localhost:4000
